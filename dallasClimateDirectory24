{ "type": "Feature", "properties": { "ObjectID": 28, "Loc_name": "CrmDallasStree", "USER_City": "Dallas", "USER_Subregion": "Dallas County", "USER_SiteName": "Juliette Fowler Communities' Garden", "USER_OldId": 0, "USER_ARC_Address": "1234 Abrams Road, Dallas, TX 75214", "Prod_Acres": 0.15, "USER_Existing": 1, "USER_Founded": "2023", "USER_ContactNam": "Cindy Wabner", "USER_Phone_1": "(214) 499-8461", "USER_Email": "<a href=\"cindy.wabner@gmail.com\" target=\"_top\">cindy.wabner@gmail.com</a>", "USER_Website": "<a href=\"https://www.facebook.com/JulietteFowlerCommunities/\" target=\"_top\">www.facebook.com/JulietteFowlerCommunities/</a>", "USER_Descriptio": "Juliette Fowler Communities is a vibrant intergenerational community in the Lakewood area of east Dallas that provides residential services and health care for more than 700 residents annually. Fowler serves hundreds of young-at-heart seniors, foster families, and young women as they age out of foster care or are abandoned.\nFowler?s community encompasses 20+ acres of park-like settings with hundreds of mature trees, garden beds, and container gardens. We adapt to our seniors? needs to make gardening easy. The Fowler gardens and amenities are used by and benefit residents, staff, chefs, and visitors. The Fowler Dallas County Master Gardener Association (DCMGA) gardening program celebrates its 20th year in 2023 and we are thrilled to have an incredibly talented, organized, and fun group of DCMGs in a long-standing relationship with Fowler residents and the garden program.\nWeekly Friday morning classes and garden activities vary depending on the season and the Fowler neighborhood in which we are working. During the heat of the summer and cold of the winter, we adapt to host horticulture crafts, cooking, or container gardening classes. Sandra Zelley, a certified horticultural therapist, leads monthly therapy classes. One challenge is watering this large community garden area due to excessive temperature variations. In the last few years, we have transitioned to native, hardier, and drought resistant plants.\nHundreds of volunteers from corporations, schools, churches, and organizations are educated by DCMGs on best horticultural practices. One example of a corporate volunteer event is our annual Deloitte Impact Day. This event yields on average 1,015 volunteer hours. This includes about 85 Deloitte employees who receive one-on-one horticultural training from 25+ DCMGA volunteers, 20 Fowler residents, and an uncounted number of employees.\nCommunity Amenities:\nSixteen raised (standing height) therapeutic garden beds\nGreenhouse for winter seeding, growing orchids, and a comfortable place to work\nSheds with most needed equipment\nCertified Monarch Way Station garden\nMedia room for monthly educational programs\nLife enrichment rooms for indoor gardening/horticultural crafts\nTest kitchen for cooking and baking\nPlantTAGG site with signage for identifying plants", "USER_Wholesale": 0.0, "USER_Retail": 0, "USER_UrbanFarm": 0, "USER_ComGRDN": 1, "USER_HomeGRDN": 1, "USER_MKTGRDN": 0, "USER_SchoolGRDN": 0, "USER_TeachingGR": 0, "USER_FaithGRDN": 0, "USER_ParkGRDN": 0, "USER_PantryGRDN": 0, "USER_OtherGRDN": 0, "USER_IndoorProd": 0, "USER_NonSoilPro": 0, "USER_OtherProdu": "0", "USER_Public_": "1", "USER_Private": 0, "USER_Nonprofit": "0", "USER_Programs": null, "USER_Partners": "Dallas County Master Gardener Association", "USER_Management": null, "USER_Crops": null, "USER_Storage": null, "USER_Distributi": null, "USER_Composting": null, "USER_Sales": null, "USER_ADA": null, "USER_SNAP": null, "USER_Zoning": null, "USER_Funding": null, "USER_LandTenure": null, "USER_PopServed": null, "USER_Needs": null, "USER_Notes": null, "USER_SiteCount": 1, "USER_Source": "DCHS", "USER_DataUpdate": "6.5.2024", "USER_ParcelType": null, "USER_Risks": null, "USER_Opportunit": null, "USER_PhotoURL": null, "USER_Notes2022": null, "USER_SiteID": null, "USER_GRDNCount": 1, "USER_Tract": null, "USER_D
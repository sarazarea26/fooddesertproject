{ "type": "Feature", "properties": { "ObjectID": 25, "Loc_name": "CrmDallasStree", "USER_City": "Dallas", "USER_Subregion": "Dallas County", "USER_SiteName": "Jill Stone Community Garden, at Temple Emanu-El", "USER_OldId": 0, "USER_ARC_Address": "8500 Hillcrest Rd, Dallas, TX 75225", "Prod_Acres": 0.75, "USER_Existing": 1, "USER_Founded": "2012", "USER_ContactNam": "Wendy Leanse; Kay McInnis", "USER_Phone_1": "(214) 502-2416; (469) 585-2859; (214) 706-0000 ext. 4002", "USER_Email": "<a href=\"shoremrcle@aol.com\" target=\"_top\">shoremrcle@aol.com</a> ; <a href=\"kaellan.mcinnis@gmail.com\" target=\"_top\">kaellan.mcinnis@gmail.com</a> ; <a href=\"hello@tedallas.org\" target=\"_top\">hello@tedallas.org</a> ; <a href=\"estrauss@tedallas.org\" target=\"_top\">estrauss@tedallas.orgg</a>", "USER_Website": "<a href=\"https://www.facebook.com/groups/101393340016250/\" target=\"_top\">www.facebook.com/groups/101393340016250/</a> ; <a href=\"https://www.tedallas.org/connect/\" target=\"_top\">www.tedallas.org/connect/</a> ; <a href=\"https://dallascountymastergardeners.org/the-jill-stone-community-garden/t\" target=\"_top\">dallascountymastergardeners.org/the-jill-stone-community-garden/</a>", "USER_Descriptio": "The Jill Stone Community Garden at Temple Emanu-El was founded and became a Master Gardener project in 2012. Its mission is to provide fresh vegetables to the Vickery Meadow Food Pantry, part of the North Texas Food Bank. The garden is 100% organic, and all of the harvest is donated. One of the Master Gardeners serves weekly at the pantry and acts as a liaison between the pantry and the garden. \n\nThis PlantTAGG-enabled garden is in the northernmost stretch of land on the Temple Emanu-El campus and encompasses 13,500 sq feet. There are 41 raised beds, trellises, additional farmers? rows, and a greenhouse. In 2020 the garden contributed just over 2.5 tons of produce and in 2021, donations are expected to exceed 3 tons. In 2023, we donated 8,000 pounds of produce. As a certified Monarch Waystation, the garden has several beds with flowering plants to attract and feed the monarchs and other pollinators.\n\nOne Master Gardener team member is employed by the Temple preschool and uses the garden as an outdoor classroom for an early education nutrition and farm-to-table program. A core group of about a dozen certified Master Gardeners enjoy sharing their knowledge with other Master Gardeners, interns, and novice gardeners from the community.\n\nEach volunteer has the opportunity to contribute and to learn about best horticultural practices in greenhouse management, plant propagation, soil amendments, growing vegetables, drip irrigation, water-wise gardening, composting, and planting for pollinators.", "USER_Wholesale": 0.0, "USER_Retail": 0, "USER_UrbanFarm": 0, "USER_ComGRDN": 1, "USER_HomeGRDN": 0, "USER_MKTGRDN": 0, "USER_SchoolGRDN": 1, "USER_TeachingGR": 1, "USER_FaithGRDN": 1, "USER_ParkGRDN": 0, "USER_PantryGRDN": 0, "USER_OtherGRDN": 0, "USER_IndoorProd": 0, "USER_NonSoilPro": 0, "USER_OtherProdu": "0", "USER_Public_": "0", "USER_Private": 1, "USER_Nonprofit": "1", "USER_Programs": "0", "USER_Partners": "Dallas County Master Gardener Association, North Texas Food Bank", "USER_Management": "Temple Emanu-El", "USER_Crops": null, "USER_Storage": null, "USER_Distributi": null, "USER_Composting": null, "USER_Sales": null, "USER_ADA": null, "USER_SNAP": null, "USER_Zoning": null, "USER_Funding": null, "USER_LandTenure": null, "USER_PopServed": null, "USER_Needs": null, "USER_Notes": " All produce is donated", "USER_SiteCount": 1, "USER_Source": "Dallas Coalition for Hunger Solutions", "USER_DataUpdate": "10.15.2024", "USER_ParcelType": null, "USER_Risks": null, "USER_Opportunit": null, "USER_PhotoURL": null, "USER_Notes2022": null, "USER_SiteID": 34.0, "USER_GRDNCount": 1, "USER_Tract": 78.01, "USER_District": 13.0 }, "geometry": { "type": "Point", "coordinates": [ -96.785414202822295, 32.868272940517897 ] } },
{ "type": "Feature", "properties": { "ObjectID": 26, "Loc_name": "CrmDallasStree", "USER_City": "Dallas", "USER_Subregion": "Dallas County", "USER_SiteName": "Joppy Momma's Farm", "USER_OldId": 0, "USER_ARC_Address": "7724 Carbondale St, Dallas, TX 75216", "Prod_Acres": 0.55, "USER_Existing": 1, "USER_Founded": "2021", "USER_ContactNam": "Kimberly High", "USER_Phone_1": "(469) 844-5229", "USER_Email": "<a href=\"info@joppymommasfarm.org\" target=\"_top\">info@joppymommasfarm.org</a>", "USER_Website": "<a href=\"https://www.joppymommas.org/\" target=\"_top\">https://www.joppymommas.org/</a>", "USER_Descriptio": "Joppy Momma's Farm is a community farm & garden located in the historic town of Joppa, just six miles south of downtown Dallas. Joppa was founded in 1872 by Henry Hines; an emancipated slave. It is one of the last Freedman towns in Texas. Although its history is rich, Joppa has endured extreme marginalization. Though nestled between the lush wetlands of the Trinity River and the Great Trinity Forest, Joppa was federally declared a food desert. Joppy Momma?s Farm vows to change that by providing healthy, affordable foods for the community. We aim to empower, educate, and create greater opportunities for health, wellness, and self-sufficiency through sustainable, regenerative agriculture. We are committed to restoring, rebuilding, and regenerating the community one seed at a time!\n\nWe are a year-round Farm that offers locals a variety of fresh farm products, produce, and family-friendly events. We specialize in Vegetables, Fresh Herbs, and Honey, but offer customers so much more! We are a nonprofit that works to create jobs, provide resources, and offer healthy food options for underserved communities.", "USER_Wholesale": 0.0, "USER_Retail": 0, "USER_UrbanFarm": 1, "USER_ComGRDN": 0, "USER_HomeGRDN": 0, "USER_MKTGRDN": 0, "USER_SchoolGRDN": 0, "USER_TeachingGR": 1, "USER_FaithGRDN": 0, "USER_ParkGRDN": 0, "USER_PantryGRDN": 0, "USER_OtherGRDN": 0, "USER_Indoo
{ "type": "Feature", "properties": { "ObjectID": 52, "Loc_name": "CrmDallasStree", "USER_City": "Dallas", "USER_Subregion": "Dallas County", "USER_SiteName": "The Hoover Kids Learning Garden, at T. R. Hoover Community Development Corporation", "USER_OldId": 0, "USER_ARC_Address": "2631 Brigham St, Dallas, TX 75215", "Prod_Acres": 0.12, "USER_Existing": 1, "USER_Founded": "N/A", "USER_ContactNam": "Sherri Mixon", "USER_Phone_1": "(214) 478-2440", "USER_Email": "<a href=\"hellosherri@msn.com\" target=\"_top\">hellosherri@msn.com</a>", "USER_Website": "<a href=\"https://www.trhoovercdc.org/\" target=\"_top\">www.trhoovercdc.org</a> ; <a href=\"https://www.facebook.com/TRhoovercdc\" target=\"_top\">https://www.facebook.com/TRhoovercdc</a>", "USER_Descriptio": "TR Hoover is a community organization that focuses on providing educational, social and community services to our South Dallas neighborhood. With the help of a team of volunteers, TR Hoover offers a variety of programs to the children and adults in our community. During the academic year, we run an after school program for 40 children and during the summer, we run a 10 week summer camp. These programs not only provide educational enhancement to our kids, we provide a safe, structured environment where they can get homework help, attend field trips and received nutritious meals. We offer ESL classes to our community members as well as weekly programming for seniors in our community. We provide members of the community access to our food pantry and clothing closet once a week. We have a learning garden that is used to not only grow organic fruits and vegetables that are distributed to our client families, but we also use the garden to teach nutrition, resilience and self-sufficiency. The garden's purpose is to not only provide food, but give a sense of community through education, arts, culture and music.\n\nMission\nT.R. Hoover's mission is to strengthen, empower, and provide holistic, collaborative services that impact the South Dallas community through affordable housing, economic, and community development. We advocate and address the issues of poverty, education, economic divestment, blight, infrastructure decline, neighborhood safety, and the rising levels of unemployment.", "USER_Wholesale": 0.0, "USER_Retail": 0, "USER_UrbanFarm": 0, "USER_ComGRDN": 0, "USER_HomeGRDN": 0, "USER_MKTGRDN": 0, "USER_SchoolGRDN": 0, "USER_TeachingGR": 1, "USER_FaithGRDN": 0, "USER_ParkGRDN": 0, "USER_PantryGRDN": 1, "USER_OtherGRDN": 0, "USER_IndoorProd": 0, "USER_NonSoilPro": 0, "USER_OtherProdu": null, "USER_Public_": null, "USER_Private": 1, "USER_Nonprofit": "1", "USER_Programs": null, "USER_Partners": null, "USER_Management": "T. R. Hoover Community Development Corporation ", "USER_Crops": null, "USER_Storage": null, "USER_Distributi": null, "USER_Composting": null, "USER_Sales": null, "USER_ADA": null, "USER_SNAP": null, "USER_Zoning": null, "USER_Funding": null, "USER_LandTenure": null, "USER_PopServed": null, "USER_Needs": null, "USER_Notes": " During the late 1980s, we established ourselves as a grassroots neighborhood association which eventually evolved into the Ideal Neighborhood Association. This association was made up of low-income families who aimed to combat the negative developments occurring in their community. In 1997, a select few from the association came together to create the T. R. Hoover Community Development Corporation (TRHCDC). This organization obtained its 501(c)(3) status and started to tackle various issues such as economic disinvestment, blight, deteriorating infrastructure, neighborhood safety concerns, and the increasing unemployment rates in the South Dallas Community.", "USER_SiteCount": 1, "USER_Source": null, "USER_DataUpdate": "5.5.2024", "USER_ParcelType": null, "USER_Risks": null, "USER_Opportunit": null, "USER_PhotoURL": null, "USER_Notes2022": null, "USER_SiteID": 54.0, "USER_GRDNCount": 1, "USER_Tract": 39.02, "USER_District": 7.0 }, "geometry":